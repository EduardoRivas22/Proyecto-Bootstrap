<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Carrera Popular Ciudad de Zaragoza</title>

  <!-- Bootstrap 5 CDN -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="estilos_bootstrap.css" rel="stylesheet">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="#">Carrera Zaragoza 2024</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="#info">Información</a></li>
          <li class="nav-item"><a class="nav-link" href="#recorrido">Recorrido</a></li>
          <li class="nav-item"><a class="nav-link" href="#inscripcion">Inscripción</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- HERO -->
<header class="hero d-flex flex-column justify-content-center align-items-center text-center text-white">
	<h1>Carrera Popular Ciudad de Zaragoza 2024</h1>
	<p class="lead">Domingo 12 de mayo · 10:00h · Parque del Agua</p>
</header>


  <!-- SECCIÓN 1: INFORMACIÓN GENERAL -->
  <section id="info" class="container">
    <h2 class="bg-primary my-4 text-white p-2 rounded text-center">Información del Evento</h2>

    <div class="row">
      <div class="col-md-6">
        <h4>¿Qué es la carrera?</h4>
        <p>
          Una carrera popular abierta a corredores de todos los niveles.  
          Distancia de 5 km y 10 km, con avituallamientos y cronometraje oficial.
        </p>
      </div>

      <div class="col-md-6">
        <h4>Detalles importantes</h4>
        <ul>
          <li>Fecha: 12 de mayo de 2024</li>
          <li>Hora de salida: 10:00h</li>
          <li>Lugar: Parque del Agua, Zaragoza</li>
          <li>Modalidades: 5K y 10K</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2: RECORRIDO (con cards) -->
  <section id="recorrido" class="container my-5">
    <h2 class="bg-primary my-4 text-white p-2 rounded text-center">Recorrido</h2>

    <div class="row">
      <div class="col-md-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Salida</h5>
            <p class="card-text">La carrera comienza en el Parque del Agua, junto al puente del Tercer Milenio.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Zona intermedia</h5>
            <p class="card-text">Recorrido llano bordeando el Ebro, ideal para mantener un ritmo constante.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Meta</h5>
            <p class="card-text">La meta se encuentra en el mismo punto de salida, con zona de avituallamiento.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3: INSCRIPCIÓN -->
  <section id="inscripcion" class="container my-5">
    <h2 class="bg-primary my-4 text-white p-2 rounded text-center">Inscripción</h2>

    <div class="row">
      <div class="col-md-6">
        <p>La inscripción incluye:</p>
        <ul>
          <li>Dorsal personalizado</li>
          <li>Cronometraje con chip</li>
          <li>Camiseta técnica</li>
          <li>Bolsa del corredor</li>
        </ul>
      </div>

      <div class="col-md-6">
        <a class="btn btn-success btn-lg w-100" href="#">Ir a la inscripción</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center p-3 mt-5">
    © 2024 Carrera Popular Ciudad de Zaragoza · Organización Deportiva Local
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
